# ==========================================================================
# Xiax-agencia — variáveis de ambiente do Paperclip
# Copie para `.env` e preencha. NUNCA commite o `.env` (está no .gitignore).
# ==========================================================================

# Porta local em que o container do Paperclip escuta (o Apache/mod_proxy da VPS
# faz o reverse proxy de um subdomínio para esta porta).
PAPERCLIP_PORT=3100

# URL pública final (o que o navegador acessa). Ajuste para o seu subdomínio.
PAPERCLIP_PUBLIC_URL=https://agencia.seu-dominio.com

# Segredo de sessão/auth. OBRIGATÓRIO. Gere um forte com:
#   openssl rand -base64 48
BETTER_AUTH_SECRET=

# Diretório de dados persistente (estado + Postgres embutido do Paperclip).
PAPERCLIP_DATA_DIR=./data/paperclip

# --------------------------------------------------------------------------
# Provedores de modelo
# --------------------------------------------------------------------------
# O agente Claude Code usa o SEU login do plano Max (subscription), então
# NÃO precisa de ANTHROPIC_API_KEY para o adaptador claude-local.
# Preencha estas só se for usar adaptadores por API key (Codex/OpenAI etc.).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
